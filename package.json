{
  "name": "creative-studio",
  "version": "1.0.0",
  "description": "Working on",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "buildcss": "npx tailwindcss -i ./flaskr/static/css/input.css -o ./flaskr/static/css/output.css --watch",
    "flask": ".venv/bin/flask run",
    "bs": "npx browser-sync start --config bs-config.js",
    "zelija": ".venv/bin/pygbag --port 8000 --can_close 1 --no_opt --ssl 0 --ume_block 0 services/zelija",
    "sablier": ".venv/bin/pygbag --port 8001 --can_close 1 --no_opt --ssl 0 --ume_block 0 services/sablier",
    "aquarium": ".venv/bin/pygbag --port 8003 --can_close 1 --no_opt --ssl 0 --ume_block 0 services/aquarium",
    "neural_transfer": "services/neural_transfer/.venv/bin/python services/neural_transfer/service.py",
    "dev": "npx concurrently \"npm run flask\" \"npm run buildcss\" \"npm run bs\" \"npm run zelija\" \"npm run neural_transfer\" \"npm run sablier\" \"npm run aquarium\" "
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frost-rvl/creative-studio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/frost-rvl/creative-studio/issues"
  },
  "homepage": "https://github.com/frost-rvl/creative-studio#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.18"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}
